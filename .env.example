# === Z.AI API Configuration ===
ZAI_API_KEY=your_api_key_here
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# === Model selection ===
# Uncomment ONE of the following models:
ZAI_MODEL=glm-5.1

# GLM 5x family (USD per 1M tokens: input / output):
# glm-5.1        $1.40 / $4.40  - Drapeau, le plus puissant
# glm-5          $1.00 / $3.20  - Base, coding SOTA open-source
# glm-5-turbo    $1.20 / $4.00  - Optimise Agent/OpenClaw

# GLM 4.x family:
# glm-4.7           $0.60 / $2.20  - Bon rapport qualite/prix
# glm-4.7-flashx    $0.07 / $0.40  - Tres peu couteux, rapide
# glm-4.7-flash     FREE / FREE    - Pour tester le pipeline
# glm-4.5-flash     FREE / FREE    - Pour tester (bientot deprecie)

# === Generation options ===
ZAI_TEMPERATURE=0.4
